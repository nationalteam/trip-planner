OPENAI_API_KEY=your-key-here
# Optional explicit provider selection: openai | azure | bifrost
# LLM_PROVIDER=openai
# Optional model override for OpenAI-compatible providers
# OPENAI_MODEL=gpt-5-mini
DATABASE_URL="file:./dev.db"

# Azure OpenAI (optional – set these to use Azure OpenAI instead of the default OpenAI API)
# AZURE_OPENAI_API_KEY=your-azure-key-here
# AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Bifrost OpenAI-compatible API (optional)
# BIFROST_API_KEY=optional-api-key
# BIFROST_BASE_URL=http://127.0.0.1:8080
