generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Trip {
  id        String   @id @default(cuid())
  name      String
  cities    String
  startDate String?
  durationDays Int?
  itineraryVisibleDays Int?
  createdAt DateTime @default(now())
  activities Activity[]
  accommodations Accommodation[]
  itineraryItems ItineraryItem[]
  members   TripMember[]
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  passwordHash String
  name        String
  preferences Preference[]
  sessions    Session[]
  tripMembers TripMember[]
}

model Preference {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  likes    String
  dislikes String
  budget   String?
  preferredLanguage String?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model TripMember {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  role      String
  createdAt DateTime @default(now())
  trip      Trip     @relation(fields: [tripId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([tripId, userId])
}

model Activity {
  id              String          @id @default(cuid())
  tripId          String
  trip            Trip            @relation(fields: [tripId], references: [id])
  type            String
  title           String
  description     String
  reason          String
  lat             Float
  lng             Float
  city            String
  suggestedTime   String
  durationMinutes Int?
  googlePlaceId   String?
  formattedAddress String?
  googleTypes     String?
  status          String          @default("pending")
  itineraryItem   ItineraryItem?
  createdAt       DateTime        @default(now())

  @@unique([tripId, googlePlaceId])
}

model ItineraryItem {
  id         String   @id @default(cuid())
  tripId     String
  trip       Trip     @relation(fields: [tripId], references: [id])
  activityId String   @unique
  activity   Activity @relation(fields: [activityId], references: [id])
  day        Int
  timeBlock  String
  order      Int      @default(0)
}

model Accommodation {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id])
  name        String
  address     String
  lat         Float?
  lng         Float?
  checkInDate String
  checkOutDate String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tripId, checkInDate])
}
