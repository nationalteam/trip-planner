generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Trip {
  id        String   @id @default(cuid())
  name      String
  cities    String
  createdAt DateTime @default(now())
  proposals Proposal[]
  itineraryItems ItineraryItem[]
}

model User {
  id          String       @id @default(cuid())
  name        String
  preferences Preference[]
}

model Preference {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  likes    String
  dislikes String
  budget   String?
}

model Proposal {
  id              String          @id @default(cuid())
  tripId          String
  trip            Trip            @relation(fields: [tripId], references: [id])
  type            String
  title           String
  description     String
  reason          String
  lat             Float
  lng             Float
  city            String
  suggestedTime   String
  durationMinutes Int?
  status          String          @default("pending")
  itineraryItem   ItineraryItem?
  createdAt       DateTime        @default(now())
}

model ItineraryItem {
  id         String   @id @default(cuid())
  tripId     String
  trip       Trip     @relation(fields: [tripId], references: [id])
  proposalId String   @unique
  proposal   Proposal @relation(fields: [proposalId], references: [id])
  day        Int
  timeBlock  String
  order      Int      @default(0)
}
